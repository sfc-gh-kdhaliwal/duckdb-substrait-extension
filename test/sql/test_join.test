# name: test/sql/test_join.test
# description: Test Join operators
# group: [sql]

require substrait

statement ok
CREATE table customer as select range c_custkey, range::VARCHAR c_name from range(10000);

# Test Full outer join
statement ok
CALL get_substrait('
    SELECT * FROM
      (SELECT c_custkey as join_custkey, c_name FROM customer WHERE c_custkey = 800) cte1
      FULL JOIN
      (SELECT c_custkey as other_custkey, c_name FROM customer WHERE c_custkey = 900) cte2
      ON join_custkey = other_custkey;
  ');